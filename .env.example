# Google Workspace OAuth. Prefer a refresh token for the Gmail/Calendar sync worker.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GMAIL_SENDER=andrew@example.com
GOOGLE_CALENDAR_ID=primary

# Required before any message can be approved for sending.
SENDER_UNSUBSCRIBE_READY=0

# Master outbound switch. Draft-only mode is the default and the safe state:
# the engine researches, writes, reviews, queues, and creates Gmail drafts, but
# NEVER calls a provider send method. Set to 1 only when you have deliberately
# decided to begin outreach — and even then, prefer sending manually from Gmail.
OUTBOUND_SENDING_ENABLED=0
