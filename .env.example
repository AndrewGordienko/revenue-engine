# Google Workspace OAuth. Prefer a refresh token for the Gmail/Calendar sync worker.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GMAIL_SENDER=andrew@example.com
GOOGLE_CALENDAR_ID=primary

# Prepares unsubscribe/suppression infrastructure used by the approval gate.
SENDER_UNSUBSCRIBE_READY=0

# NOTE: There is no outbound-sending flag. Sending is intentionally not
# implemented in this build — the engine can create Gmail drafts but cannot send.
# Sending will be reintroduced only in a dedicated, explicitly reviewed change.
